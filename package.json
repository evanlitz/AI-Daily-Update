{
  "name": "ai-pulse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --max-old-space-size=4096 node_modules/next/dist/bin/next dev",
    "build": "node --max-old-space-size=4096 node_modules/next/dist/bin/next build",
    "start": "next start",
    "eval:capture": "node --env-file=.env.local --import tsx scripts/eval/capture-golden-set.mts",
    "eval:run": "node --env-file=.env.local --import tsx scripts/eval/run-eval.mts",
    "eval:advisor:capture": "node --env-file=.env.local --import tsx scripts/eval/capture-advisor-golden-set.mts",
    "eval:advisor:run": "node --env-file=.env.local --import tsx scripts/eval/run-eval-advisor.mts",
    "eval:prediction:capture": "node --env-file=.env.local --import tsx scripts/eval/capture-prediction-golden-set.mts",
    "eval:prediction:run": "node --env-file=.env.local --import tsx scripts/eval/run-eval-prediction.mts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@libsql/client": "^0.17.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/he": "^1.2.3",
    "@types/xml2js": "^0.4.14",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.2.0",
    "he": "^1.2.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rss-parser": "^3.13.0",
    "voyageai": "^0.4.0",
    "xml2js": "^0.6.2",
    "youtube-transcript": "^1.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
